# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/xwite

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# REDIS
REDIS_URL=redis://localhost:6379

# RAZORPAY
RAZORPAY_KEY_ID=your_key_id
