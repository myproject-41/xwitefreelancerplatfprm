# AI AGENT
ANTHROPIC_API_KEY=your_anthropic_key

# APP
PORT=4000
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
