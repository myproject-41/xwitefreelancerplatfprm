{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "../prisma/schema.prisma"
  },
  "scripts": {
    "dev": "node scripts/free-port.mjs && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "migrate": "dotenv -e ../.env -- prisma migrate dev --schema ../prisma/schema.prisma",
    "migrate:prod": "dotenv -e ../.env -- prisma migrate deploy --schema ../prisma/schema.prisma",
    "seed": "dotenv -e ../.env -- prisma db seed --schema ../prisma/schema.prisma",
    "studio": "dotenv -e ../.env -- prisma studio --schema ../prisma/schema.prisma",
    "generate": "dotenv -e ../.env -- prisma generate --schema ../prisma/schema.prisma",
    "db:push": "dotenv -e ../.env -- prisma db push --schema ../prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.19.2",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "cloudinary": "^2.5.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "razorpay": "^2.9.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.7.0",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@prisma/client": "5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.14",
    "eslint": "^8",
    "prisma": "5.22.0",
    "tsx": "^4.7.1",
    "typescript": "^5"
  }
}
